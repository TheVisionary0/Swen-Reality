<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Main Website</title>
  <style>
    body {
      background-color: #0a0a0a;
      color: #ffffff;
      font-family: 'Courier New', monospace;
      text-align: center;
      margin: 0;
      padding: 0;
    }

    img {
      width: 200px;
      margin-top: 50px;
      filter: drop-shadow(0 0 10px red);
    }

    #passwordBox {
      margin-top: 50px;
    }

    input[type="password"] {
      padding: 10px;
      font-size: 18px;
      border: none;
      border-radius: 5px;
    }

    button {
      padding: 10px 20px;
      font-size: 18px;
      margin-left: 10px;
      border: none;
      border-radius: 5px;
      background-color: red;
      color: white;
      cursor: pointer;
    }

    button:hover {
      background-color: darkred;
    }

    #hint {
      margin-top: 20px;
      font-size: 14px;
      color: #888;
    }
  </style>
</head>
<body>

  <!-- Top Eye Image -->
  <img src="https://images-wixmp-ed30a86b8c4ca887773594c2.wixmp.com/f/805d3cf6-7d6e-49e8-94eb-7308079bc696/dhue8bn-6dae10ed-cbe8-4066-b34f-28d942f69a54.png/v1/fill/w_920,h_598/creepy_eye_png_by_solarmaker2005_dhue8bn-fullview.png?token=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..bsOk63azFOKbO8sqSJYQ5_DIXesqlNyqicxqzu98OeQ" alt="Creepy Eye">

  <!-- Password Input Box -->
  <div id="passwordBox">
    <input type="password" id="passwordInput" placeholder="Enter password">
    <button onclick="checkPassword()">Enter</button>
  </div>

  <div id="hint">Hint: Find the password in the description of the post on ArtStreet.</div>

  <script>
    // Replace 'YOURPASSWORD' with the actual password from your ArtStreet post
    const correctPassword = "YOURPASSWORD";

    function checkPassword() {
      const userInput = document.getElementById("passwordInput").value;
      if (userInput === correctPassword) {
        // Redirect to case files page
        window.location.href = "casefiles.html";
      } else {
        alert("Incorrect password. Keep searching...");
      }
    }
  </script>

</body>
</html>
